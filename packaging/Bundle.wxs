<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidTreeView - optional WiX v5 Burn bootstrapper.

  This bundle is for framework-dependent MSIs. It detects the Microsoft .NET 10 Desktop Runtime for
  the target architecture and silently installs it before chaining the AndroidTreeView MSI.

  Build after the MSI has been produced:

      wix build packaging/Bundle.wxs -arch x64 ^
          -d ProductVersion=1.0.7 ^
          -d Platform=x64 ^
          -d MsiPath=artifacts\AndroidTreeView-1.0.7-x64.msi ^
          -d DotNetRuntimeExe=C:\path\windowsdesktop-runtime-10.0.x-win-x64.exe ^
          -ext WixToolset.BootstrapperApplications.wixext ^
          -ext WixToolset.Netfx.wixext ^
          -o artifacts\AndroidTreeView-1.0.7-x64-setup.exe
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">

  <Bundle
      Name="AndroidTreeView"
      Manufacturer="Birditch"
      Version="$(var.ProductVersion)"
      UpgradeCode="{A1D2C3B4-5E6F-4708-9182-3B4C5D6E7F80}"
      AboutUrl="https://github.com/Birditch/AndroidTreeView">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          Theme="hyperlinkLicense"
          SuppressOptionsUI="yes"
          LicenseUrl="https://github.com/Birditch/AndroidTreeView/blob/main/LICENSE" />
    </BootstrapperApplication>

    <netfx:DotNetCoreSearch
        Id="SearchDotNetDesktop10"
        RuntimeType="desktop"
        Platform="$(var.Platform)"
        MajorVersion="10"
        Variable="DotNetDesktop10" />

    <Chain>
      <ExePackage
          Id="DotNetDesktopRuntime10"
          DisplayName="Microsoft .NET Desktop Runtime 10 ($(var.Platform))"
          Cache="remove"
          PerMachine="yes"
          Permanent="yes"
          Vital="yes"
          DetectCondition="DotNetDesktop10 AND (DotNetDesktop10 &gt;= v10.0.0)"
          InstallArguments="/install /quiet /norestart"
          RepairArguments="/repair /quiet /norestart"
          SourceFile="$(var.DotNetRuntimeExe)">
        <ExitCode Value="0" Behavior="success" />
        <ExitCode Value="1602" Behavior="error" />
        <ExitCode Value="3010" Behavior="scheduleReboot" />
      </ExePackage>

      <MsiPackage
          Id="AndroidTreeViewApp"
          SourceFile="$(var.MsiPath)"
          Vital="yes"
          DisplayInternalUI="no" />
    </Chain>
  </Bundle>
</Wix>
