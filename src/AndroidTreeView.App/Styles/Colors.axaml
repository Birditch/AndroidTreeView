<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Colors.axaml — light + dark palette (layered backgrounds, surfaces, foregrounds, borders)
        plus the theme-neutral accent. Theme-varying resources live in ThemeDictionaries keyed by
        ThemeVariant (Light / Dark); the accent stays neutral so IThemeService.ApplyAccent can
        override "AccentBrush" cleanly at runtime.
    -->

    <!-- Theme-neutral accent (default; ThemeService may override AccentBrush) -->
    <Color x:Key="AccentColor">#0F766E</Color>
    <Color x:Key="AccentColorHover">#14B8A6</Color>
    <Color x:Key="AccentColorPressed">#0D9488</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="AccentBrushHover" Color="{DynamicResource AccentColorHover}" />
    <SolidColorBrush x:Key="AccentBrushPressed" Color="{DynamicResource AccentColorPressed}" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />

    <ResourceDictionary.ThemeDictionaries>

        <!-- ================= LIGHT ================= -->
        <ResourceDictionary x:Key="Light">
            <!-- Layered background palette -->
            <Color x:Key="BackgroundBaseTopColor">#F4F6F3</Color>
            <Color x:Key="BackgroundBaseBottomColor">#E7ECE7</Color>
            <Color x:Key="BackgroundLayer1Color">#F7F8F5</Color>
            <Color x:Key="BackgroundLayer2Color">#FFFFFF</Color>
            <!-- Surfaces -->
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="SurfaceAltColor">#EEF3EF</Color>
            <!-- Foregrounds -->
            <Color x:Key="ForegroundColor">#171A18</Color>
            <Color x:Key="ForegroundSecondaryColor">#4F5751</Color>
            <Color x:Key="ForegroundTertiaryColor">#7B847D</Color>
            <!-- Borders / dividers -->
            <Color x:Key="BorderSubtleColor">#D8DED6</Color>
            <Color x:Key="DividerColor">#E5E9E3</Color>

            <!-- Background: soft vertical gradient for depth behind glass -->
            <LinearGradientBrush x:Key="BackgroundBaseBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#F4F6F3" />
                <GradientStop Offset="1" Color="#E7ECE7" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="BackgroundLayer1Brush" Color="{DynamicResource BackgroundLayer1Color}" />
            <SolidColorBrush x:Key="BackgroundLayer2Brush" Color="{DynamicResource BackgroundLayer2Color}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
            <SolidColorBrush x:Key="ForegroundBrush" Color="{DynamicResource ForegroundColor}" />
            <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="{DynamicResource ForegroundSecondaryColor}" />
            <SolidColorBrush x:Key="ForegroundTertiaryBrush" Color="{DynamicResource ForegroundTertiaryColor}" />
            <SolidColorBrush x:Key="BorderSubtleBrush" Color="{DynamicResource BorderSubtleColor}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}" />
        </ResourceDictionary>

        <!-- ================= DARK ================= -->
        <ResourceDictionary x:Key="Dark">
            <!-- Layered background palette -->
            <Color x:Key="BackgroundBaseTopColor">#121411</Color>
            <Color x:Key="BackgroundBaseBottomColor">#0C0D0C</Color>
            <Color x:Key="BackgroundLayer1Color">#171916</Color>
            <Color x:Key="BackgroundLayer2Color">#20221F</Color>
            <!-- Surfaces -->
            <Color x:Key="SurfaceColor">#1E211D</Color>
            <Color x:Key="SurfaceAltColor">#282C27</Color>
            <!-- Foregrounds -->
            <Color x:Key="ForegroundColor">#F4F5EF</Color>
            <Color x:Key="ForegroundSecondaryColor">#C2C8BE</Color>
            <Color x:Key="ForegroundTertiaryColor">#8B9489</Color>
            <!-- Borders / dividers -->
            <Color x:Key="BorderSubtleColor">#373D35</Color>
            <Color x:Key="DividerColor">#2C322B</Color>

            <!-- Background: soft vertical gradient for depth behind glass -->
            <LinearGradientBrush x:Key="BackgroundBaseBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#121411" />
                <GradientStop Offset="1" Color="#0C0D0C" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="BackgroundLayer1Brush" Color="{DynamicResource BackgroundLayer1Color}" />
            <SolidColorBrush x:Key="BackgroundLayer2Brush" Color="{DynamicResource BackgroundLayer2Color}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
            <SolidColorBrush x:Key="ForegroundBrush" Color="{DynamicResource ForegroundColor}" />
            <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="{DynamicResource ForegroundSecondaryColor}" />
            <SolidColorBrush x:Key="ForegroundTertiaryBrush" Color="{DynamicResource ForegroundTertiaryColor}" />
            <SolidColorBrush x:Key="BorderSubtleBrush" Color="{DynamicResource BorderSubtleColor}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
