<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AndroidTreeView.App.ViewModels"
             xmlns:controls="using:AndroidTreeView.App.Controls"
             xmlns:loc="using:AndroidTreeView.App.Localization"
             mc:Ignorable="d"
             x:Class="AndroidTreeView.App.Views.DeviceCardView"
             x:DataType="vm:DeviceCardViewModel"
             x:CompileBindings="True">

    <!-- Card is informational: the card itself shows key facts. Actions live in the right-click ContextMenu. -->
    <Border Classes="deviceCard"
            Width="320"
            Margin="8"
            CornerRadius="8"
            Padding="18"
            Background="{DynamicResource Glass.Card.Background}"
            BorderBrush="{DynamicResource Glass.Card.Border}"
            BorderThickness="1">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{loc:Localize Key=menu.detail}"
                          Command="{Binding OpenCommand}"
                          IsVisible="{Binding CanOpenDetail}" />
                <MenuItem Header="{loc:Localize Key=menu.screen}" Command="{Binding OpenScreenCommand}" />
                <MenuItem Header="{loc:Localize Key=menu.cli}" Command="{Binding OpenCliCommand}" />
                <MenuItem Header="{loc:Localize Key=menu.adbtools}">
                    <MenuItem Header="{loc:Localize Key=menu.frp}" Command="{Binding RemoveFrpCommand}" />
                </MenuItem>
                <MenuItem Header="{loc:Localize Key=menu.power}">
                    <MenuItem Header="{loc:Localize Key=menu.reboot}" Command="{Binding RebootSystemCommand}" />
                    <MenuItem Header="{loc:Localize Key=menu.recovery}" Command="{Binding RebootRecoveryCommand}" />
                    <MenuItem Header="{loc:Localize Key=menu.fastboot}" Command="{Binding EnterFastbootCommand}" />
                    <MenuItem Header="{loc:Localize Key=menu.poweroff}" Command="{Binding PowerOffCommand}" />
                </MenuItem>
            </ContextMenu>
        </Border.ContextMenu>

        <StackPanel Spacing="12">

            <!-- Header: multi-select checkbox + name + device index -->
            <DockPanel>
                <CheckBox DockPanel.Dock="Left"
                          IsChecked="{Binding IsSelected}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Index, StringFormat='#{0}'}"
                           Opacity="0.6"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding DisplayName}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <!-- Status badges -->
            <WrapPanel Orientation="Horizontal">
                <controls:StatusBadge Text="{Binding StatusText}"
                                      Kind="{Binding StatusKind}"
                                      Margin="0,0,6,6" />

                <Border IsVisible="{Binding IsMirroring}"
                        Background="{DynamicResource Badge.Mirroring}"
                        CornerRadius="8"
                        Padding="8,3"
                        Margin="0,0,6,6">
                    <TextBlock Text="{loc:Localize Key=status.mirroring}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <Border IsVisible="{Binding IsRooted, TargetNullValue=false}"
                        Background="{DynamicResource Badge.Root}"
                        CornerRadius="8"
                        Padding="8,3"
                        Margin="0,0,6,6">
                    <TextBlock Text="{loc:Localize Key=status.rooted}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <Border IsVisible="{Binding MagiskInstalled}"
                        Background="{DynamicResource Badge.Magisk}"
                        CornerRadius="8"
                        Padding="8,3"
                        Margin="0,0,6,6">
                    <TextBlock Text="{loc:Localize Key=status.magisk}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <Border IsVisible="{Binding IsNotRooted}"
                        Background="{DynamicResource Badge.NotRooted}"
                        CornerRadius="8"
                        Padding="8,3"
                        Margin="0,0,6,6">
                    <TextBlock Text="{loc:Localize Key=status.notrooted}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <Border IsVisible="{Binding IsCharging}"
                        Background="{DynamicResource Badge.Charging}"
                        CornerRadius="8"
                        Padding="8,3"
                        Margin="0,0,6,6">
                    <TextBlock Text="{loc:Localize Key=status.charging}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <Border IsVisible="{Binding IsLowBattery}"
                        Background="{DynamicResource Badge.LowBattery}"
                        CornerRadius="8"
                        Padding="8,3"
                        Margin="0,0,6,6">
                    <TextBlock Text="{loc:Localize Key=status.lowbattery}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
            </WrapPanel>

            <!-- Battery (shows the % inside the indicator) — hidden in fastboot (no OS to read) -->
            <controls:BatteryIndicator Level="{Binding BatteryPercent}"
                                       IsCharging="{Binding IsCharging}"
                                       IsLow="{Binding IsLowBattery}"
                                       IsVisible="{Binding !IsFastboot}" />

            <!-- Normal device facts (booted into the system) -->
            <StackPanel Spacing="2" IsVisible="{Binding !IsFastboot}">
                <controls:InfoRow Label="{loc:Localize Key=overview.manufacturer}" Value="{Binding Manufacturer}" />
                <controls:InfoRow Label="{loc:Localize Key=overview.model}" Value="{Binding Model}" />
                <controls:InfoRow Label="{loc:Localize Key=overview.android}" Value="{Binding AndroidVersion}" />
                <controls:InfoRow Label="{loc:Localize Key=overview.oem.allowed}" Value="{Binding OemUnlockAllowedText}" />
                <controls:InfoRow Label="{loc:Localize Key=overview.bootloaderlock}" Value="{Binding BootloaderLockText}" />
                <controls:InfoRow Label="{loc:Localize Key=overview.devicestate}" Value="{Binding DeviceStateText}" />
                <controls:InfoRow Label="{loc:Localize Key=card.temperature}" Value="{Binding TemperatureText}" />
                <controls:InfoRow Label="{loc:Localize Key=card.serial}" Value="{Binding Serial}" />
            </StackPanel>

            <!-- Cycle count (self-describing; shows the localized "Unavailable" text when unknown) -->
            <TextBlock Text="{Binding CycleCountText}"
                       FontSize="12"
                       Opacity="0.8"
                       TextTrimming="CharacterEllipsis"
                       IsVisible="{Binding !IsFastboot}" />

            <!-- Fastboot-only facts (curated from `fastboot getvar all`) — special treatment for bootloader mode -->
            <ItemsControl IsVisible="{Binding IsFastboot}" ItemsSource="{Binding FastbootFacts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FastbootFact">
                        <controls:InfoRow Label="{Binding Label}" Value="{Binding Value}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
