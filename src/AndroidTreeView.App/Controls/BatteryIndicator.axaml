<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AndroidTreeView.App.Controls"
             x:Class="AndroidTreeView.App.Controls.BatteryIndicator"
             x:CompileBindings="False"
             HorizontalAlignment="Left"
             VerticalAlignment="Center"
             MinWidth="74"
             MinHeight="22">
    <UserControl.Styles>
        <Style Selector="controls|BatteryIndicator:low Border#PART_Body">
            <Setter Property="BorderBrush" Value="#DC2626" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="*,Auto">
        <Border x:Name="PART_Body"
                Grid.Column="0"
                BorderBrush="#66808080"
                BorderThickness="2"
                Background="#22808080"
                CornerRadius="5"
                Padding="3"
                ClipToBounds="True">
            <Grid>
                <!-- Proportional fill: column 0 grows with Level, column 1 shrinks (set in code). -->
                <Grid x:Name="PART_Track" ColumnDefinitions="0*,100*">
                    <Border x:Name="PART_Fill"
                            Grid.Column="0"
                            CornerRadius="2"
                            Background="{Binding Level, RelativeSource={RelativeSource AncestorType=controls:BatteryIndicator}, Converter={StaticResource BatteryLevelToBrush}}" />
                </Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="1">
                    <TextBlock Text="&#x26A1;"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="Black"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsCharging, RelativeSource={RelativeSource AncestorType=controls:BatteryIndicator}}" />
                    <TextBlock Text="{Binding Level, RelativeSource={RelativeSource AncestorType=controls:BatteryIndicator}, StringFormat='{}{0}%'}"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="Black"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Battery cap: middle 50% of the body height, scales with size. -->
        <Grid Grid.Column="1" RowDefinitions="1*,2*,1*" Margin="1,0,0,0">
            <Border Grid.Row="1"
                    Width="4"
                    VerticalAlignment="Stretch"
                    CornerRadius="0,2,2,0"
                    Background="#66808080" />
        </Grid>
    </Grid>
</UserControl>
