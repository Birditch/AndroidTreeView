<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AndroidTreeView.App.Controls"
             x:Class="AndroidTreeView.App.Controls.StatusBadge"
             x:CompileBindings="False">
    <Border Background="{Binding Kind, RelativeSource={RelativeSource AncestorType=controls:StatusBadge}, Converter={StaticResource BadgeKindToBrush}}"
            CornerRadius="8"
            Padding="8,3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
        <TextBlock Text="{Binding Text, RelativeSource={RelativeSource AncestorType=controls:StatusBadge}}"
                   Foreground="White"
                   FontSize="11"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
    </Border>
</UserControl>
