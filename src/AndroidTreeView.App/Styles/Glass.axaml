<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Glass.axaml — card / sidebar surface brushes.
        NOTE: the "liquid glass" (translucent + acrylic blur) look was removed by request. These are now
        fully OPAQUE, high-contrast surfaces for a clean, readable developer-tool style. Keys are kept so
        existing views/controls keep working. Theme-varying values live in ThemeDictionaries (Light/Dark);
        shared geometry (corner radii) stays neutral at the root.

        Required keys: Glass.Card.Background, Glass.Card.BackgroundHover, Glass.Card.Border,
        Glass.Sidebar.Background, plus card BoxShadows (Glass.Card.Shadow / Glass.Card.ShadowHover).
    -->

    <!-- Shared geometry (theme-neutral) -->
    <CornerRadius x:Key="Card.CornerRadius">8</CornerRadius>
    <CornerRadius x:Key="Control.CornerRadius">8</CornerRadius>
    <CornerRadius x:Key="Pill.CornerRadius">999</CornerRadius>

    <ResourceDictionary.ThemeDictionaries>

        <!-- ================= LIGHT ================= -->
        <ResourceDictionary x:Key="Light">
            <!-- Solid white cards on the light gray-blue background; crisp hairline border -->
            <SolidColorBrush x:Key="Glass.Card.Background" Color="#FFFFFFFE" />
            <SolidColorBrush x:Key="Glass.Card.BackgroundHover" Color="#FFF2F6F1" />
            <SolidColorBrush x:Key="Glass.Card.Border" Color="#FFD8DED6" />
            <SolidColorBrush x:Key="Glass.Sidebar.Background" Color="#FFF1F4EF" />
            <SolidColorBrush x:Key="Glass.Update.Background" Color="#FFE9F8F1" />
            <SolidColorBrush x:Key="Glass.Update.Border" Color="#FF8DD6BD" />

            <!-- Subtle drop shadow for depth (not a glass effect) -->
            <BoxShadows x:Key="Glass.Card.Shadow">0 2 10 0 #120B1410</BoxShadows>
            <BoxShadows x:Key="Glass.Card.ShadowHover">0 8 22 0 #1F0B1410</BoxShadows>
        </ResourceDictionary>

        <!-- ================= DARK ================= -->
        <ResourceDictionary x:Key="Dark">
            <!-- Solid slate cards, lifted above the dark base; clear border for separation -->
            <SolidColorBrush x:Key="Glass.Card.Background" Color="#FF20221F" />
            <SolidColorBrush x:Key="Glass.Card.BackgroundHover" Color="#FF292D28" />
            <SolidColorBrush x:Key="Glass.Card.Border" Color="#FF373D35" />
            <SolidColorBrush x:Key="Glass.Sidebar.Background" Color="#FF171916" />
            <SolidColorBrush x:Key="Glass.Update.Background" Color="#FF10231F" />
            <SolidColorBrush x:Key="Glass.Update.Border" Color="#FF1F7A68" />

            <!-- Subtle drop shadow for depth (not a glass effect) -->
            <BoxShadows x:Key="Glass.Card.Shadow">0 2 8 0 #40000000</BoxShadows>
            <BoxShadows x:Key="Glass.Card.ShadowHover">0 6 16 0 #59000000</BoxShadows>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
