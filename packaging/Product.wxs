<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidTreeView MSI - WiX v5 authoring.

  Preprocessor variables supplied by AndroidTreeView.Package.wixproj:
    $(var.ProductVersion)     e.g. 1.0.6
    $(var.ProductName)        display name
    $(var.ProductExecutable)  main executable file in PublishDir
    $(var.ProductUpgradeCode) stable MSI UpgradeCode
    $(var.ProductInstallFolder) install folder name
    $(var.ProductRegistryKey) registry key suffix under Software\Birditch
    $(var.PackagePlatform)    x64
    $(var.SelfContained)      true | false
    $(var.PublishDir)         absolute path with trailing '\' to the dotnet publish output

  Installs per machine:
    * every file from the publish output into <Program Files>\$(var.ProductInstallFolder)
    * a Start Menu shortcut
    * an optional desktop shortcut (INSTALLDESKTOPSHORTCUT=1)

  Framework-dependent builds include a best-effort .NET 10 Desktop Runtime check.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <?define ProgramFilesDir = "ProgramFiles64Folder" ?>
  <?define DotNetRegistryBitness = "always64" ?>

  <Package
      Name="$(var.ProductName)"
      Manufacturer="Birditch"
      Version="$(var.ProductVersion)"
      UpgradeCode="$(var.ProductUpgradeCode)"
      Scope="perMachine"
      Compressed="yes"
      InstallerVersion="500"
      Language="1033">

    <MajorUpgrade
        DowngradeErrorMessage="A newer version of [ProductName] is already installed. Setup will now exit." />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="ProductIcon.exe" SourceFile="$(var.PublishDir)$(var.ProductExecutable)" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon.exe" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Birditch/AndroidTreeView" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/Birditch/AndroidTreeView" />

    <!-- Optional desktop shortcut: msiexec /i <product>-1.0.6-x64.msi INSTALLDESKTOPSHORTCUT=1 -->
    <Property Id="INSTALLDESKTOPSHORTCUT" Value="0" Secure="yes" />

    <?if $(var.SelfContained) = "false" ?>
      <Property Id="CHECKDOTNET" Value="1" Secure="yes" />
      <Property Id="DOTNETDESKTOPHOST">
        <RegistrySearch
            Id="DotNetDesktopHost"
            Root="HKLM"
            Bitness="$(var.DotNetRegistryBitness)"
            Key="SOFTWARE\dotnet\Setup\InstalledVersions\$(var.PackagePlatform)\sharedhost"
            Name="Version"
            Type="raw" />
      </Property>
      <Launch
          Condition="Installed OR (CHECKDOTNET &lt;&gt; &quot;1&quot;) OR DOTNETDESKTOPHOST"
          Message="$(var.ProductName) requires the Microsoft .NET Desktop Runtime 10 ($(var.PackagePlatform)). Install it from https://dotnet.microsoft.com/download/dotnet/10.0 and run this installer again. (To bypass this check, run msiexec with CHECKDOTNET=0.)" />
    <?endif?>

    <StandardDirectory Id="$(var.ProgramFilesDir)">
      <Directory Id="INSTALLFOLDER" Name="$(var.ProductInstallFolder)" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="$(var.ProductName)" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainApplication" Title="$(var.ProductName)" Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="AppShortcuts" />
    </Feature>

    <Feature Id="DesktopShortcutFeature" Title="Desktop Shortcut" Level="1" AllowAbsent="yes">
      <Level Value="0" Condition="INSTALLDESKTOPSHORTCUT &lt;&gt; &quot;1&quot;" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)**" />
    </ComponentGroup>

    <ComponentGroup Id="AppShortcuts">
      <Component Id="StartMenuShortcut" Directory="AppShortcutFolder" Guid="*">
        <Shortcut Id="StartMenuAppShortcut"
                  Name="$(var.ProductName)"
                  Description="$(var.ProductDescription)"
                  Target="[INSTALLFOLDER]$(var.ProductExecutable)"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="ProductIcon.exe" />
        <RemoveFolder Id="RemoveAppShortcutFolder" Directory="AppShortcutFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\Birditch\$(var.ProductRegistryKey)"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
      <Shortcut Id="DesktopAppShortcut"
                Name="$(var.ProductName)"
                Description="$(var.ProductDescription)"
                Target="[INSTALLFOLDER]$(var.ProductExecutable)"
                WorkingDirectory="INSTALLFOLDER"
                Icon="ProductIcon.exe" />
      <RegistryValue Root="HKCU"
                     Key="Software\Birditch\$(var.ProductRegistryKey)"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

  </Package>
</Wix>
