<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AndroidTreeView.App.ViewModels"
             xmlns:controls="using:AndroidTreeView.App.Controls"
             xmlns:conv="using:AndroidTreeView.App.Converters"
             xmlns:loc="using:AndroidTreeView.App.Localization"
             xmlns:opt="using:AndroidTreeView.Core.Options"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="720" d:DesignHeight="900"
             x:Class="AndroidTreeView.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

    <UserControl.Resources>
        <conv:SettingsEnumMatchConverter x:Key="EnumMatch" />
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" Padding="20">
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Stretch">

            <TextBlock Text="{loc:Localize Key=settings.title}"
                       FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />

            <!-- Appearance: theme + accent -->
            <controls:SectionCard Header="{loc:Localize Key=settings.theme}">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="4">
                        <RadioButton GroupName="ThemeGroup"
                                     Content="{loc:Localize Key=settings.theme.system}"
                                     IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static opt:ThemeMode.System}}" />
                        <RadioButton GroupName="ThemeGroup"
                                     Content="{loc:Localize Key=settings.theme.light}"
                                     IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static opt:ThemeMode.Light}}" />
                        <RadioButton GroupName="ThemeGroup"
                                     Content="{loc:Localize Key=settings.theme.dark}"
                                     IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static opt:ThemeMode.Dark}}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="{loc:Localize Key=settings.accent}" Opacity="0.8" />
                        <TextBox Text="{Binding AccentColor}" Watermark="#0A84FF" MaxWidth="200" HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </controls:SectionCard>

            <!-- Language -->
            <controls:SectionCard Header="{loc:Localize Key=settings.language}">
                <StackPanel Spacing="4">
                    <RadioButton GroupName="LanguageGroup"
                                 Content="{loc:Localize Key=settings.language.system}"
                                 IsChecked="{Binding Language, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static opt:AppLanguage.System}}" />
                    <RadioButton GroupName="LanguageGroup"
                                 Content="{loc:Localize Key=settings.language.zh}"
                                 IsChecked="{Binding Language, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static opt:AppLanguage.ChineseSimplified}}" />
                    <RadioButton GroupName="LanguageGroup"
                                 Content="{loc:Localize Key=settings.language.en}"
                                 IsChecked="{Binding Language, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static opt:AppLanguage.English}}" />
                </StackPanel>
            </controls:SectionCard>

            <!-- Updates -->
            <controls:SectionCard Header="{loc:Localize Key=update.check}">
                <StackPanel Spacing="12">
                    <Border Classes="softPanel">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding UpdateStatusText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding UpdateSource}"
                                               Classes="caption"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Content="{loc:Localize Key=settings.autoupdate}"
                                          IsChecked="{Binding AutoCheckUpdates}"
                                          VerticalAlignment="Top" />
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Classes="versionTile">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{loc:Localize Key=update.current}" Classes="caption" />
                                        <TextBlock Text="{Binding CurrentVersion}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="versionTile">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{loc:Localize Key=update.latest}" Classes="caption" />
                                        <TextBlock Text="{Binding LatestVersion, Converter={StaticResource NullOrEmptyToDash}}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <controls:InfoRow Label="{loc:Localize Key=update.source}" Value="{Binding UpdateSource}" />
                    <controls:InfoRow Label="{loc:Localize Key=update.key}" Value="{Binding UpdateKey}" />

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="{loc:Localize Key=update.openrelease}" Command="{Binding OpenReleasesCommand}" />
                        <Button Content="{loc:Localize Key=update.install}"
                                Command="{Binding InstallUpdateCommand}"
                                IsEnabled="{Binding CanInstallUpdate}" />
                        <Button Content="{loc:Localize Key=update.check}" Command="{Binding CheckUpdatesCommand}" Classes="accent" />
                    </StackPanel>
                </StackPanel>
            </controls:SectionCard>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="{loc:Localize Key=common.reset}" Command="{Binding ResetCommand}" />
                <Button Content="{loc:Localize Key=common.save}" Command="{Binding SaveCommand}" Classes="accent" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
