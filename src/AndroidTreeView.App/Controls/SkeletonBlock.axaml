<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AndroidTreeView.App.Controls"
             x:Class="AndroidTreeView.App.Controls.SkeletonBlock"
             x:CompileBindings="False"
             MinHeight="16">
    <Border x:Name="PART_Shimmer"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#33808080"
            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=controls:SkeletonBlock}}">
        <Border.Styles>
            <Style Selector="Border#PART_Shimmer">
                <Style.Animations>
                    <Animation Duration="0:0:1.3"
                               IterationCount="INFINITE"
                               PlaybackDirection="Alternate"
                               Easing="SineEaseInOut">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="0.35" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="0.85" />
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>
    </Border>
</UserControl>
