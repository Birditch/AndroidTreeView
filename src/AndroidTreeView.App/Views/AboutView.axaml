<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AndroidTreeView.App.ViewModels"
             xmlns:controls="using:AndroidTreeView.App.Controls"
             xmlns:loc="using:AndroidTreeView.App.Localization"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="640" d:DesignHeight="520"
             x:Class="AndroidTreeView.App.Views.AboutView"
             x:DataType="vm:AboutViewModel"
             x:CompileBindings="True">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" Padding="24">
        <StackPanel Spacing="18" HorizontalAlignment="Stretch">

            <TextBlock Text="{loc:Localize Key=about.title}"
                       FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Left" />

            <controls:SectionCard Header="{loc:Localize Key=app.title}">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding AppName}" FontSize="20" FontWeight="SemiBold" />
                    <controls:InfoRow Label="{loc:Localize Key=update.current}" Value="{Binding Version}" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="{loc:Localize Key=about.project}" Opacity="0.8" />
                        <Button Content="{Binding ProjectUrl}" Command="{Binding OpenProjectCommand}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </controls:SectionCard>

            <controls:SectionCard Header="{loc:Localize Key=update.check}">
                <StackPanel Spacing="12">
                    <Border Classes="softPanel">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding UpdateStatusText}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Classes="versionTile">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{loc:Localize Key=update.current}" Classes="caption" />
                                        <TextBlock Text="{Binding Version}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="versionTile">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{loc:Localize Key=update.latest}" Classes="caption" />
                                        <TextBlock Text="{Binding LatestVersion, Converter={StaticResource NullOrEmptyToDash}}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <controls:InfoRow Label="{loc:Localize Key=update.source}" Value="{Binding UpdateSource}" />
                    <controls:InfoRow Label="{loc:Localize Key=update.key}" Value="{Binding UpdateKey}" />

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="{loc:Localize Key=update.openrelease}" Command="{Binding OpenReleasesCommand}" />
                        <Button Content="{loc:Localize Key=update.install}"
                                Command="{Binding InstallUpdateCommand}"
                                IsEnabled="{Binding CanInstallUpdate}" />
                        <Button Content="{loc:Localize Key=update.check}" Command="{Binding CheckUpdatesCommand}"
                                Classes="accent" />
                    </StackPanel>
                </StackPanel>
            </controls:SectionCard>

        </StackPanel>
    </ScrollViewer>
</UserControl>
