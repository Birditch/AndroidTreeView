<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AndroidTreeView.App.Controls"
             x:Class="AndroidTreeView.App.Controls.SkeletonBlock"
             x:CompileBindings="False"
             MinHeight="16">
    <UserControl.Styles>
        <!-- Only animate while the skeleton is effectively visible (:active is set from
             code-behind on IsEffectivelyVisible). When the skeleton is collapsed by a parent,
             the animation clock stops so the render loop can sleep instead of repainting every
             frame — otherwise the shimmer keeps the whole UI redrawing and the app feels laggy. -->
        <Style Selector="controls|SkeletonBlock:active Border#PART_Shimmer">
            <Style.Animations>
                <Animation Duration="0:0:1.3"
                           IterationCount="INFINITE"
                           PlaybackDirection="Alternate"
                           Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.35" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.85" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
    <Border x:Name="PART_Shimmer"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#33808080"
            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=controls:SkeletonBlock}}" />
</UserControl>
